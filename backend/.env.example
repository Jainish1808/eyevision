# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=Eyewear E-commerce API
APP_ENV=development
DEBUG=true
API_PREFIX=/api

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=sqlite+aiosqlite:///./eyewear.db
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=eyewear

# ============================================================================
# REDIS (Required for sessions, caching, and token blacklist)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2

# ============================================================================
# JWT TOKENS
# Generate secrets with: openssl rand -hex 32
# ============================================================================
JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# SESSION MANAGEMENT
# ============================================================================
SESSION_SECRET_KEY=<generate-with-openssl-rand-hex-32>
SESSION_MAX_AGE=86400
SESSION_IDLE_TIMEOUT=3600
SESSION_ABSOLUTE_TIMEOUT=86400

# ============================================================================
# OAUTH2 (Optional - Leave empty if not using)
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/oauth/callback

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=<generate-with-openssl-rand-hex-32>
ENCRYPTION_KEY=<generate-with-python-cryptography-fernet>
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
MFA_ISSUER_NAME=Eyewear Store
CSRF_SECRET=<generate-with-openssl-rand-hex-32>

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_API=100/minute
RATE_LIMIT_PASSWORD_RESET=3/hour

# ============================================================================
# COOKIE SETTINGS (Set COOKIE_SECURE=true in production with HTTPS)
# ============================================================================
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ============================================================================
# SECURITY HEADERS
# ============================================================================
HSTS_MAX_AGE=31536000
CSP_POLICY=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;

# ============================================================================
# AUDIT LOGGING
# ============================================================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=logs/audit.log

# ============================================================================
# FRONTEND URL
# ============================================================================
FRONTEND_URL=http://localhost:5173

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production:
# 1. Set APP_ENV=production
# 2. Set DEBUG=false
# 3. Generate all secrets with: openssl rand -hex 32
# 4. Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 5. Set COOKIE_SECURE=true
# 6. Set COOKIE_SAMESITE=strict or lax
# 7. Configure CORS_ORIGINS with your production domain
# 8. Set up proper REDIS_URL (not localhost)
# 9. Set up proper MONGODB_URL (not localhost)
# 10. Configure OAuth2 credentials if using social login
# 11. Never commit this file to git!
