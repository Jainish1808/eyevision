# =============================================
# EYEWEARS E-COMMERCE - BACKEND ENVIRONMENT
# =============================================

# ---------- Application Settings ----------
APP_NAME="Eyewear E-commerce API"
APP_ENV="development"  # development | production
DEBUG=True
API_PREFIX="/api"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ---------- Database Configuration ----------
# PostgreSQL (Production)
DATABASE_URL="postgresql://eyewear_user:your_password@localhost:5432/eyeware_db"

# SQLite (Development fallback)
# DATABASE_URL="sqlite+aiosqlite:///./eyewear.db"

# ---------- JWT Settings ----------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# ---------- Google OAuth ----------
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ---------- Security ----------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-secret-key-for-password-hashing"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ---------- Rate Limiting ----------
RATE_LIMIT_PER_MINUTE=60

# ---------- Email (Optional - for future OTP) ----------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
FROM_EMAIL="noreply@eyewear.com"

# ---------- Storage (for product images) ----------
STORAGE_TYPE="local"  # local | s3
LOCAL_STORAGE_PATH="./storage/products"
# AWS S3 (if needed)
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_STORAGE_BUCKET_NAME=""
# AWS_REGION="us-east-1"
